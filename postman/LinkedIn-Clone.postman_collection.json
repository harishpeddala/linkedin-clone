{
  "info": {
    "name": "LinkedIn Clone API",
    "description": "REST API endpoints for the LinkedIn Clone backend. Auth uses an httpOnly `token` cookie set on login/register — Postman stores it automatically, so run a Login request first, then the protected requests will work in the same collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"f_name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<google-id-token>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google"]
            }
          }
        },
        {
          "name": "Get Self",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/self",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "self"]
            }
          }
        },
        {
          "name": "Get Profile By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/user/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "user", ":id"],
              "variable": [{ "key": "id", "value": "<userId>" }]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"f_name\": \"Updated Name\",\n    \"headline\": \"Software Engineer\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/update",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "update"]
            }
          }
        },
        {
          "name": "Find User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/findUser?query=test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "findUser"],
              "query": [{ "key": "query", "value": "test" }]
            }
          }
        },
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"<userId>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sendFriendRequest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sendFriendRequest"]
            }
          }
        },
        {
          "name": "Accept Friend Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"<userId>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/acceptFriendRequest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "acceptFriendRequest"]
            }
          }
        },
        {
          "name": "Get Friends List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/getFriendsList",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "getFriendsList"]
            }
          }
        },
        {
          "name": "Get Pending Friends List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/getPendingFriendsList",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "getPendingFriendsList"]
            }
          }
        },
        {
          "name": "Remove Friend",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/removeFriend/:friendId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "removeFriend", ":friendId"],
              "variable": [{ "key": "friendId", "value": "<userId>" }]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
